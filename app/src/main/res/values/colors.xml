<?xml version="1.0" encoding="utf-8"?>
<resources>

    <color name="window_color">@color/md_white_1000</color>
    <color name="window_color_light">@color/md_white_1000</color>
    <color name="window_color_dark">@android:color/black</color>

    <color name="twenty_percent_black_overlay">#34000000</color>
    <color name="app_shortcut_default_foreground">#607d8b</color>
    <color name="app_shortcut_default_background">#f5f5f5</color>
    <color name="md_indigo_A400">#3D5AFE</color>

    <!-- App base theme (gradient) -->
    <color name="theme_gradient_start">#11D5D5</color>
    <color name="theme_gradient_end">#0FD35A</color>
    <!-- Solid representative of the gradient, used as the ATE accent color -->
    <color name="theme_accent">#11D5D5</color>

    <!-- Material3 color scheme derived from the teal (#11D5D5) → green (#0FD35A) base.
         Teal drives the "primary" role, green the "secondary" role. -->
    <!-- Light scheme -->
    <color name="scheme_light_primary">#006A6B</color>
    <color name="scheme_light_on_primary">#FFFFFF</color>
    <color name="scheme_light_primary_container">#6FF6F6</color>
    <color name="scheme_light_on_primary_container">#002020</color>
    <color name="scheme_light_secondary">#006D3B</color>
    <color name="scheme_light_on_secondary">#FFFFFF</color>
    <color name="scheme_light_secondary_container">#74FDA0</color>
    <color name="scheme_light_on_secondary_container">#00210E</color>
    <!-- Dark scheme -->
    <color name="scheme_dark_primary">#4CD9DA</color>
    <color name="scheme_dark_on_primary">#003737</color>
    <color name="scheme_dark_primary_container">#004F50</color>
    <color name="scheme_dark_on_primary_container">#6FF6F6</color>
    <color name="scheme_dark_secondary">#55E082</color>
    <color name="scheme_dark_on_secondary">#00391C</color>
    <color name="scheme_dark_secondary_container">#005227</color>
    <color name="scheme_dark_on_secondary_container">#74FDA0</color>

    <!-- Adaptive (DayNight) aliases → light values here, dark values in values-night -->
    <color name="md_theme_primary">@color/scheme_light_primary</color>
    <color name="md_theme_on_primary">@color/scheme_light_on_primary</color>
    <color name="md_theme_primary_container">@color/scheme_light_primary_container</color>
    <color name="md_theme_on_primary_container">@color/scheme_light_on_primary_container</color>
    <color name="md_theme_secondary">@color/scheme_light_secondary</color>
    <color name="md_theme_on_secondary">@color/scheme_light_on_secondary</color>
    <color name="md_theme_secondary_container">@color/scheme_light_secondary_container</color>
    <color name="md_theme_on_secondary_container">@color/scheme_light_on_secondary_container</color>

    <color name="dark_color">#202124</color>
    <color name="black_color">#202124</color>

    <color name="darkColorPrimary">#202124</color>
    <color name="darkColorSurface">#202124</color>

    <color name="darkerColorSurface">#353535</color>
    <color name="lighterColorSurface">#dddddd</color>

    <color name="blackColorSurface">#000000</color>

    <color name="transparent">#00000000</color>
    <color name="semi_transparent">#20000000</color>
    <!-- card colors -->
    <color name="card_background">#ffffff</color>
    <color name="card_shadow_1">#d4d4d4</color>
    <color name="card_shadow_2">#dddddd</color>

    <color name="progress_gray">#FFD8D8D8</color>
    <color name="default_blue_light">#ff33b5e5</color>

    <color name="bottomSheetColorLight">#FFFFFF</color>
    <color name="bottomSheetColorDark">#202020</color>
    <color name="bottomSheetColorBlack">#000000</color>

    <color name="bottomSheetColor">#FFFFFF</color>
    <color name="widget_md3_bg_color">@color/lighterColorSurface</color>
    <color name="widget_circle_button_color">@color/md_indigo_A400</color>
    <color name="widget_md3_button_bg_color">@color/lighterColorSurface</color>
</resources>
